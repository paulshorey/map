# PostgreSQL connection (web/server builds only)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poi_map

# Thunderforest premium tiles (optional)
THUNDERFOREST_API_KEY=

# Required for Capacitor mobile builds — URL of the deployed Next.js server
# that hosts /api/* routes (e.g. https://poi-map.example.com)
NEXT_PUBLIC_API_URL=
