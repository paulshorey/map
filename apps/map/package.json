{
  "name": "map",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "contracts:check": "pnpm --filter @lib/db-map app:contract:check",
    "build": "pnpm run contracts:check && next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next",
    "check-types": "pnpm run contracts:check && tsc --noEmit",
    "verify": "pnpm run check-types && pnpm run build",
    "build:mobile": "tsx scripts/build-capacitor.ts",
    "cap:sync": "pnpm run build:mobile",
    "cap:ios": "pnpm run build:mobile && npx cap open ios",
    "cap:android": "pnpm run build:mobile && npx cap open android",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@lib/db-map": "workspace:*",
    "@tanstack/react-query": "^5.100.14",
    "maplibre-gl": "^5.24.0",
    "next": "^15.3.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-map-gl": "^8.1.1"
  },
  "devDependencies": {
    "@lib/config": "workspace:*",
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  }
}
