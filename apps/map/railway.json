{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter map build",
    "watchPatterns": [
      "apps/map/**",
      "lib/db-map/**",
      "lib/config/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter map start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30
  }
}
